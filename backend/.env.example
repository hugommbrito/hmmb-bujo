# Backend environment template — copy to .env.dev (Neon dev branch),
# .env.prod (Neon main branch) or .env.e2e (Neon e2e branch, usado pela suíte
# E2E do Playwright). Todos os arquivos reais são git-ignored; só este template
# é versionado. Never commit real secrets.

# Selects the settings module:
#   config.settings.dev  → branch Neon dev
#   config.settings.prod → branch Neon main
#   config.settings.e2e  → branch Neon e2e (isolada; os testes escrevem aqui)
#   config.settings.test → Postgres LOCAL (docker-compose); usado por `uv run pytest`
#
# A suíte pytest usa `config.settings.test` por padrão (ver pyproject.toml) →
# aponta para um Postgres local em vez do Neon remoto (rápido, sem cold start, e
# sem poluir a branch dev). Suba o banco uma vez a partir da raiz do repo:
#   docker compose up -d db
#   cd backend && uv run pytest
# `config.settings.test` é self-contained (defaults localhost via setdefault), então
# não precisa de arquivo .env para testes.
DJANGO_SETTINGS_MODULE=config.settings.dev

# Django secret key — generate a unique value per environment.
SECRET_KEY=changeme-dev-only-replace-with-50-char-random-string

# Debug should be True only in dev.
DEBUG=True

# Neon connection string. The ?sslmode=require comes from the URL itself
# (do NOT hardcode SSL options in settings — CI's ephemeral Postgres has no SSL).
DATABASE_URL=postgres://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# Comma-separated hosts allowed to serve the app.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins allowed for CORS (the Vite dev server, etc.).
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Taxa do rate limit da captura externa (POST /api/capture, escopo
# "automation-capture"). Formato DRF "<n>/<período>" (s|min|hour|day).
# Aplicado per-view via ScopedRateThrottle; default 60/min se ausente.
AUTOMATION_CAPTURE_THROTTLE=60/min

# Taxa do rate limit do resumo do dia (GET /api/summary/today, escopo
# "automation-summary"). Mesmo formato/mecanismo do capture; default 60/min.
AUTOMATION_SUMMARY_THROTTLE=60/min
