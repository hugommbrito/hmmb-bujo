# Backend environment template — copy to .env.dev (Neon dev branch),
# .env.prod (Neon main branch) or .env.e2e (Neon e2e branch, usado pela suíte
# E2E do Playwright). Todos os arquivos reais são git-ignored; só este template
# é versionado. Never commit real secrets.

# Selects the settings module:
#   config.settings.dev  → branch Neon dev
#   config.settings.prod → branch Neon main
#   config.settings.e2e  → branch Neon e2e (isolada; os testes escrevem aqui)
DJANGO_SETTINGS_MODULE=config.settings.dev

# Django secret key — generate a unique value per environment.
SECRET_KEY=changeme-dev-only-replace-with-50-char-random-string

# Debug should be True only in dev.
DEBUG=True

# Neon connection string. The ?sslmode=require comes from the URL itself
# (do NOT hardcode SSL options in settings — CI's ephemeral Postgres has no SSL).
DATABASE_URL=postgres://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# Comma-separated hosts allowed to serve the app.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins allowed for CORS (the Vite dev server, etc.).
CORS_ALLOWED_ORIGINS=http://localhost:5173
