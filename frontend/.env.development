# Dev: requests go to a relative /api, proxied to the backend by Vite (no CORS).
# Empty on purpose — every call already hardcodes its own /api/... path
# (see features/*/api.ts); a non-empty base here double-prefixes every
# request to /api/api/... (404). Vite's server.proxy rule in vite.config.ts
# is what forwards the relative /api/... path to the Django backend.
VITE_API_BASE_URL=
# VITE_API_BASE_URL="https://hmmb-bujo-api-production.up.railway.app"
